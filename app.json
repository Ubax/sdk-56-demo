{
  "expo": {
    "name": "sdk-56-demo",
    "slug": "sdk-56-demo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sdk56demo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.jtkacz.sdk56demo",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.jtkacz.sdk56demo"
    },
    "web": {
      "output": "server",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://ubax-sdk-56-demo.expo.app",
          "unstable_useServerMiddleware": true,
          "unstable_useServerDataLoaders": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-widgets",
        {
          "widgets": [
            {
              "name": "SdkWidget",
              "displayName": "SDK Widget",
              "description": "Shows an Expo SDK release",
              "ios": {
                "contentMarginsDisabled": true,
                "supportedFamilies": [
                  "systemSmall",
                  "systemMedium"
                ],
                "configuration": {
                  "title": "Options",
                  "description": "Show the prev/next arrows on the medium widget",
                  "parameters": {
                    "showButtons": {
                      "title": "Show arrows",
                      "type": "boolean",
                      "default": true
                    }
                  }
                }
              }
            }
          ]
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "ExpoWidgetsTarget",
                  "bundleIdentifier": "com.jtkacz.sdk56demo.ExpoWidgetsTarget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.jtkacz.sdk56demo"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "98e13aec-80e4-458a-9041-4a294114f99a"
      }
    }
  }
}
